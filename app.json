{
  "expo": {
    "name": "Aura 🔥 – Chat, ligar & Sentimientos",
    "slug": "palpitos",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/aura_logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "palpitos",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.palpitos.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Palpitos necesita acceso a tu cámara para que puedas tomar fotos y enviarlas a tu pareja.",
        "NSPhotoLibraryUsageDescription": "Palpitos necesita acceso a tus fotos para que puedas enviar imágenes privadas a tu pareja.",
        "NSPhotoLibraryAddUsageDescription": "Palpitos necesita permiso para guardar fotos en tu galería.",
        "NSMicrophoneUsageDescription": "Palpitos necesita acceso al micrófono para grabar mensajes de voz.",
        "NSUserNotificationsUsageDescription": "Palpitos te enviará notificaciones cuando tu pareja te envíe mensajes o imágenes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/aura_logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.palpitos.app",
      "versionCode": 2,
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Palpitos necesita acceso a tus fotos para que puedas enviar imágenes privadas a tu pareja.",
          "cameraPermission": "Palpitos necesita acceso a tu cámara para que puedas tomar fotos y enviarlas a tu pareja.",
          "microphonePermission": "Palpitos necesita acceso al micrófono para grabar mensajes de voz."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B9D",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Nuevo mensaje de tu pareja ❤️"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "supabaseUrl": "https://rrimgqumfozqfpskthoc.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJyaW1ncXVtZm96cWZwc2t0aG9jIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njc3MDgxMTcsImV4cCI6MjA4MzI4NDExN30.KEi1p-DgkmDYSsqrBmUYknZ7RoA_KvllWgHWx1pEKfg",
      "eas": {
        "projectId": "5b6e44e7-78ce-44fb-bd75-f9b96e6bbcd5"
      }
    },
    "owner": "sebasing04"
  }
}
